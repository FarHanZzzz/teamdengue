# Copy to .env and adjust for production. Defaults run fully locally.

# LLM — enables real AI for the agent + assistant (free OpenRouter models w/ fallback).
# Get a key at https://openrouter.ai/keys . Without it, a deterministic engine is used.
# OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override the fallback chain (comma-separated free model slugs)
# OPENROUTER_MODELS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free
# Backup provider — used automatically when OpenRouter is rate-limited / out of tokens.
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODELS=gemini-2.5-flash,gemini-flash-latest

# Database — swap to a Supabase/Postgres DSN in production
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/prevdengue

# Alert delivery (leave SIMULATE_ALERTS=true to log instead of sending)
SIMULATE_ALERTS=true
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# Risk thresholds (PRD 6.2)
THRESHOLD_MEDIUM=0.26
THRESHOLD_HIGH=0.51
THRESHOLD_CRITICAL=0.76
